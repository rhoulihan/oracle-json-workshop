# Oracle Database
# SYS/SYSTEM password for the Oracle container
ORACLE_PASSWORD=WorkshopAdmin2026
# Password for the WORKSHOP_ADMIN schema (app connects as this user)
APP_USER_PASSWORD=WorkshopApp2026

# Workshop App — Database Connection
DB_USER=WORKSHOP_ADMIN
DB_PASSWORD=WorkshopApp2026
# Use container name for Docker, localhost for local dev
DB_CONNECT_STRING=workshop-oracle:1521/FREEPDB1

# ORDS (Oracle REST Data Services)
ORDS_BASE_URL=http://workshop-oracle:8181/ords

# MongoDB API (via ORDS)
MONGODB_URI=mongodb://workshop-oracle:27017

# Session — change this to a random 32+ character string in production
SESSION_SECRET=change-me-to-a-random-string

# Instructor Dashboard — password for /admin.html
ADMIN_PASSWORD=instructor2026
INSTRUCTOR_PASSWORD=instructor2026

# Optional
PORT=3000
NODE_ENV=production
